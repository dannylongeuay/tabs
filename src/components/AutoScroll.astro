---
// Auto-scroll island: a fixed, icon-only play/pause button (bottom-right) plus
// the scroll engine. Speed is controlled by the numeric +/- control rendered in
// the settings sidebar (looked up by ID) and persisted per song in localStorage.
// Uses requestAnimationFrame to scroll by `speed * dt`. Manual scroll, wheel,
// touch, or arrow/space keys pause it. Stops when the page bottom is reached.

interface Props {
  songId: string;
}

const { songId } = Astro.props;
---

<button
  id="scroll-toggle"
  class="scroll-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Start/stop auto-scroll"
  title="Auto-scroll"
>
  <span class="icon-play">▶</span>
  <span class="icon-stop" hidden>⏹</span>
</button>

<script is:inline define:vars={{ songId }}>
  (function () {
    var btn = document.getElementById("scroll-toggle");
    if (!btn) return;
    var iconPlay = btn.querySelector(".icon-play");
    var iconStop = btn.querySelector(".icon-stop");
    var dec = document.getElementById("scroll-dec");
    var inc = document.getElementById("scroll-inc");
    var valueEl = document.getElementById("scroll-speed-value");

    var KEY = "scrollSpeed:" + songId;
    var MIN = 2;
    var MAX = 30;
    var STEP = 2;
    var DEFAULT = 10;

    // Per-song speed, falling back to the legacy global key on first load.
    var saved = NaN;
    try {
      saved = parseFloat(localStorage.getItem(KEY));
      if (isNaN(saved)) saved = parseFloat(localStorage.getItem("scrollSpeed"));
    } catch (e) {}
    var speed = isNaN(saved) ? DEFAULT : saved; // px per second

    var playing = false;
    var rafId = null;
    var lastTs = 0;
    // Accumulate fractional pixels so slow speeds still scroll smoothly.
    var carry = 0;
    // Where we'd be if only our own scrollBy calls had moved the page. Any gap
    // between this and the real scrollY means the user scrolled, so we stop.
    // (A synchronous "ignore" flag can't work: scroll events fire async, after
    // the flag is reset.)
    var expectedY = 0;

    function clamp(v) {
      return Math.max(MIN, Math.min(MAX, v));
    }

    function setSpeed(v) {
      speed = clamp(v);
      if (valueEl) valueEl.textContent = String(speed);
      try {
        localStorage.setItem(KEY, String(speed));
      } catch (e) {}
    }

    function atBottom() {
      return (
        window.innerHeight + window.scrollY >=
        document.documentElement.scrollHeight - 1
      );
    }

    function frame(ts) {
      if (!playing) return;
      if (!lastTs) lastTs = ts;
      var dt = (ts - lastTs) / 1000;
      lastTs = ts;

      carry += speed * dt;
      var px = Math.floor(carry);
      if (px > 0) {
        carry -= px;
        window.scrollBy(0, px);
        // Read the actual resulting position rather than accumulating an
        // idealized integer. On iOS Safari (Retina), scrollY snaps to the
        // device-pixel grid, so integer scrollBy calls don't move the page by
        // exactly `px` CSS pixels; accumulating would drift past the threshold
        // below and falsely stop auto-scroll within a second.
        expectedY = window.scrollY;
      }

      if (atBottom()) {
        stop();
        return;
      }
      rafId = requestAnimationFrame(frame);
    }

    function start() {
      if (playing) return;
      if (atBottom()) return;
      playing = true;
      lastTs = 0;
      carry = 0;
      expectedY = window.scrollY;
      btn.setAttribute("aria-pressed", "true");
      if (iconPlay) iconPlay.hidden = true;
      if (iconStop) iconStop.hidden = false;
      rafId = requestAnimationFrame(frame);
    }

    function stop() {
      playing = false;
      if (rafId) cancelAnimationFrame(rafId);
      rafId = null;
      btn.setAttribute("aria-pressed", "false");
      if (iconPlay) iconPlay.hidden = false;
      if (iconStop) iconStop.hidden = true;
    }

    btn.addEventListener("click", function () {
      if (playing) stop();
      else start();
    });

    if (dec) dec.addEventListener("click", function () { setSpeed(speed - STEP); });
    if (inc) inc.addEventListener("click", function () { setSpeed(speed + STEP); });

    // Reflect the initial (persisted) speed in the display.
    setSpeed(speed);

    // Any manual interaction pauses auto-scroll.
    window.addEventListener(
      "wheel",
      function () {
        if (playing) stop();
      },
      { passive: true }
    );
    window.addEventListener(
      "touchstart",
      function (e) {
        // Don't treat taps on our own controls (toggle button, settings) as a
        // manual scroll — otherwise the toggle would pause here and immediately
        // re-start on the subsequent click.
        if (
          e.target &&
          e.target.closest &&
          e.target.closest(".scroll-toggle, .settings")
        ) {
          return;
        }
        if (playing) stop();
      },
      { passive: true }
    );
    window.addEventListener("keydown", function (e) {
      if (!playing) return;
      var keys = [
        "ArrowUp",
        "ArrowDown",
        "PageUp",
        "PageDown",
        "Home",
        "End",
        " ",
        "Spacebar",
      ];
      if (keys.indexOf(e.key) !== -1) stop();
    });
    window.addEventListener(
      "scroll",
      function () {
        // A position that drifts from where our own scrolling put us means the
        // user took over. Small threshold absorbs sub-pixel rounding.
        if (playing && Math.abs(window.scrollY - expectedY) > 3) stop();
      },
      { passive: true }
    );
  })();
</script>
