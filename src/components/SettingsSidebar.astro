---
// Settings island: a fixed cog button (bottom-left) that toggles a small popover
// anchored above it. The popover holds slotted settings controls (lyrics-only
// toggle, scroll speed). Closes on cog re-click, outside click, or Escape.
---

<div class="settings">
  <div id="settings-panel" class="settings-panel" hidden>
    <slot />
  </div>
  <button
    id="settings-cog"
    class="settings-cog"
    type="button"
    aria-expanded="false"
    aria-controls="settings-panel"
    aria-label="Settings"
    title="Settings"
  >
    ⚙
  </button>
</div>

<script is:inline>
  (function () {
    var wrap = document.querySelector(".settings");
    var cog = document.getElementById("settings-cog");
    var panel = document.getElementById("settings-panel");
    if (!wrap || !cog || !panel) return;

    function setOpen(open) {
      panel.hidden = !open;
      cog.setAttribute("aria-expanded", open ? "true" : "false");
    }

    cog.addEventListener("click", function (e) {
      e.stopPropagation();
      setOpen(panel.hidden);
    });

    // Clicks inside the popover shouldn't close it.
    panel.addEventListener("click", function (e) {
      e.stopPropagation();
    });

    document.addEventListener("click", function () {
      if (!panel.hidden) setOpen(false);
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !panel.hidden) setOpen(false);
    });
  })();
</script>
