---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const songs = await getCollection("songs");
const items = songs
  .map((s) => ({
    slug: s.id,
    title: s.data.title,
    artist: s.data.artist,
    tags: s.data.tags ?? [],
  }))
  .sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout title="Songs">
  <h1>Songs</h1>

  <div class="directory-controls">
    <input
      id="filter"
      type="search"
      placeholder="Filter by title, artist, or tag…"
      aria-label="Filter songs"
    />
    <button id="sort-toggle" class="btn" type="button" data-sort="title">
      Sort: Title
    </button>
  </div>

  <ul class="song-list" id="song-list">
    {
      items.map((s) => (
        <li
          data-title={s.title.toLowerCase()}
          data-artist={s.artist.toLowerCase()}
          data-tags={s.tags.join(" ").toLowerCase()}
        >
          <a href={`/songs/${s.slug}`}>
            <span class="title">{s.title}</span>
            <span class="meta">
              {" — "}
              {s.artist}
              {s.tags.length > 0 && ` · ${s.tags.map((t) => "#" + t).join(" ")}`}
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  {items.length === 0 && <p>No songs yet.</p>}
</BaseLayout>

<script is:inline>
  (function () {
    var filter = document.getElementById("filter");
    var list = document.getElementById("song-list");
    var sortBtn = document.getElementById("sort-toggle");
    if (!filter || !list || !sortBtn) return;
    var items = Array.prototype.slice.call(list.querySelectorAll("li"));

    function applyFilter() {
      var q = filter.value.trim().toLowerCase();
      items.forEach(function (li) {
        var hay =
          li.getAttribute("data-title") +
          " " +
          li.getAttribute("data-artist") +
          " " +
          li.getAttribute("data-tags");
        li.hidden = q !== "" && hay.indexOf(q) === -1;
      });
    }

    function applySort() {
      var key = sortBtn.getAttribute("data-sort"); // "title" | "artist"
      var sorted = items.slice().sort(function (a, b) {
        var av = a.getAttribute("data-" + key) || "";
        var bv = b.getAttribute("data-" + key) || "";
        return av.localeCompare(bv);
      });
      sorted.forEach(function (li) {
        list.appendChild(li);
      });
    }

    filter.addEventListener("input", applyFilter);
    sortBtn.addEventListener("click", function () {
      var next =
        sortBtn.getAttribute("data-sort") === "title" ? "artist" : "title";
      sortBtn.setAttribute("data-sort", next);
      sortBtn.textContent = "Sort: " + (next === "title" ? "Title" : "Artist");
      applySort();
    });
  })();
</script>
